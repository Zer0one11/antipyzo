{
  "version": 2,
  "builds": [
    {
      "src": "server.py",
      "use": "@vercel/python",
      "config": { "wsgi_handler": "server.server" }
    }
  ],
  "routes": [
    {
      "src": "/(style\\.css|app\\.js)",
      "dest": "/static/$1"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/static/assets/$1"
    },
    {
      "src": "/(.*)",
      "dest": "server.py"
    }
  ]
}
